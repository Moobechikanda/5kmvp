{
  "name": "solopreneur-tools",
  "version": "1.0.0",
  "description": "Eleventy theme for solopreneur tools blog",
  "type": "module",
  "scripts": {
    "dev:css": "tailwindcss -i ./src/styles/input.css -o ./src/assets/css/styles.css --watch",
    "dev": "npm run build:css && eleventy --serve --watch",
    "start": "npm run dev",
    "build:css": "tailwindcss -i ./src/styles/input.css -o ./src/assets/css/styles.css --minify",
    "build": "npm run build:css && eleventy",
    "clean": "rm -rf _site"
  },
  "devDependencies": {
    "@11ty/eleventy": "^3.1.6",
    "@11ty/eleventy-plugin-syntaxhighlight": "^5.0.2",
    "autoprefixer": "^10.5.2",
    "markdown-it": "^14.2.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19"
  }
}
