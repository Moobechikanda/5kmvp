---
layout: base.njk
permalink: /categories/{{ category.slug }}/index.html
pagination:
  data: categories
  size: 1
  alias: category
---

{% set categoryArticles = collections.articles | filterByCategory(category.slug) %}

<section class="bg-muted/30">
  <div class="container mx-auto px-4 py-12">
    <nav class="mb-6 flex items-center gap-2 text-sm text-muted-foreground">
      <a href="/" class="hover:text-foreground">Home</a>
      <span>/</span>
      <a href="/categories" class="hover:text-foreground">Categories</a>
      <span>/</span>
      <span class="text-foreground">{{ category.name }}</span>
    </nav>

    <div class="flex items-center gap-4 mb-4">
      <div class="h-12 w-12 rounded-lg flex items-center justify-center" style="background-color: {{ category.color }}20">
        <div class="h-4 w-4 rounded-full" style="background-color: {{ category.color }}"></div>
      </div>
      <h1 class="text-4xl font-bold">{{ category.name }}</h1>
    </div>

    <p class="text-lg text-muted-foreground max-w-2xl">{{ category.description }}</p>
    <p class="mt-4 text-sm text-muted-foreground">{{ categoryArticles.length }} articles</p>
  </div>
</section>

<section class="container mx-auto px-4 py-12">
  {% if categoryArticles.length > 0 %}
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {% for article in categoryArticles %}
    <article class="group relative overflow-hidden rounded-xl border bg-card transition-all hover:shadow-lg">
      <a href="{{ article.url }}">
        {% if article.data.image %}
        <div class="aspect-video overflow-hidden">
          <img
            src="{{ article.data.image.url }}"
            alt="{{ article.data.image.alt }}"
            loading="lazy"
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
          />
        </div>
        {% endif %}
        <div class="p-5">
          <div class="mb-3 flex items-center gap-2">
            <span class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
              {{ article.data.category | capitalize }}
            </span>
          </div>
          <h3 class="mb-2 text-xl font-bold leading-tight group-hover:text-primary">
            {{ article.data.title }}
          </h3>
          <p class="mb-4 line-clamp-2 text-muted-foreground">
            {{ article.data.description }}
          </p>
          <div class="flex items-center justify-between text-sm text-muted-foreground">
            <time datetime="{{ article.data.pubDate | dateFormat('iso') }}">
              {{ article.data.pubDate | dateFormat }}
            </time>
            {% if article.data.readingTime %}
            <span>{{ article.data.readingTime }} min read</span>
            {% endif %}
          </div>
        </div>
      </a>
    </article>
    {% endfor %}
  </div>
  {% else %}
  <p class="text-muted-foreground text-center">No articles in this category yet.</p>
  {% endif %}
</section>

