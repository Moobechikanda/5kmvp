---
layout: base.njk
title: Reviews
description: Compare the best tools and services for your workflow.
permalink: /reviews/
---

<section class="container mx-auto px-4 py-12">
  <h1 class="mb-8 text-4xl font-bold">Reviews</h1>

  <div class="grid gap-6">
    {% for article in collections.reviews %}
    <article class="rounded-xl border p-6">
      <h2 class="mb-2 text-2xl font-bold">
        <a href="{{ article.url }}">{{ article.data.title }}</a>
      </h2>
      <p>{{ article.data.description }}</p>
    </article>
    {% endfor %}
  </div>
</section>
