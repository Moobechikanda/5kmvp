{% if title %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": {{ (seo.title if seo and seo.title else title) | dump | safe }},
  "description": {{ (seo.description if seo and seo.description else description | default(site.site.description)) | dump | safe }},
  "datePublished": {{ (date if date else pubDate) | dump | safe }},
  {% if lastUpdated %}
  "dateModified": {{ lastUpdated | dump | safe }},
  {% else %}
  "dateModified": {{ (date if date else pubDate) | dump | safe }},
  {% endif %}
  "author": {
    "@type": "Person",
    "name": {{ (author if author else site.site.author) | dump | safe }}
  },
  "publisher": {
    "@type": "Organization",
    "name": {{ site.site.name | dump | safe }},
    "logo": {
      "@type": "ImageObject",
      "url": "{{ site.site.url }}{{ site.site.logo | default('/images/logo.png') }}"
    }
  },
  "mainEntityOfPage": {
    "@type": "WebPage",
    "@id": "{{ site.site.url }}{{ page.url }}"
  }
  {% if image %},
  "image": [
    "{{ site.site.url }}{{ image }}"
  ]
  {% endif %}
}
</script>

{% if rating %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Review",
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": "{{ rating }}",
    "bestRating": "5"
  },
  "author": {
    "@type": "Person",
    "name": {{ (author if author else site.site.author) | dump | safe }}
  },
  "itemReviewed": {
    "@type": "SoftwareApplication",
    "name": {{ (tool or title) | dump | safe }}
  }
  {% if officialWebsite %},
  "url": "{{ officialWebsite }}"
  {% endif %}
}
</script>
{% endif %}

{% if faq and faq.length %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {% for item in faq %}
    {
      "@type": "Question",
      "name": {{ item.question | dump | safe }},
      "acceptedAnswer": {
        "@type": "Answer",
        "text": {{ item.answer | dump | safe }}
      }
    }
    {% if not loop.last %},{% endif %}
    {% endfor %}
  ]
}
</script>
{% endif %}

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    {
      "@type": "ListItem",
      "position": 1,
      "name": "Home",
      "item": "{{ site.site.url }}"
    }
    {% if type %},
    {
      "@type": "ListItem",
      "position": 2,
      "name": "{{ type }}",
      "item": "{{ site.site.url }}/{{ type | lower }}s/"
    },
    {
      "@type": "ListItem",
      "position": 3,
      "name": {{ title | dump | safe }},
      "item": "{{ site.site.url }}{{ page.url }}"
    }
    {% endif %}
  ]
}
</script>
{% endif %}
