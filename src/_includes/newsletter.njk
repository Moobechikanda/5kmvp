<div class="rounded-xl bg-primary/5 p-8 text-center">
  <h2 class="mb-2 text-2xl font-bold">Stay Updated</h2>
  <p class="mb-6 text-muted-foreground">Get the latest tools and tips delivered to your inbox.</p>

  <form class="mx-auto flex max-w-md flex-col gap-4 sm:flex-row">
    <input
      type="email"
      placeholder="Enter your email"
      class="flex-1 rounded-lg border bg-background px-4 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-primary"
      required
    >
    <button
      type="submit"
      class="rounded-lg bg-primary px-6 py-2 text-sm font-medium text-primary-foreground hover:bg-primary/90"
    >
      Subscribe
    </button>
  </form>

  <p class="mt-4 text-xs text-muted-foreground">No spam. Unsubscribe anytime.</p>
</div>
