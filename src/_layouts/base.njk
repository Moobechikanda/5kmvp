<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="theme-color" content="#0f172a">
  <meta name="author" content="{{ site.site.author }}">
  <meta name="keywords" content="{{ keywords | default('solopreneur tools, software reviews, guides, comparisons, productivity tools, automation tools') }}">
  <title>
    {% if seo and seo.title %}
    {{ seo.title }}
    {% else %}
    {{ title }} | {{ site.site.name }}
    {% endif %}
  </title>

  <meta name="description" content="{% if seo and seo.description %}{{ seo.description }}{% else %}{{ description | default(site.site.description) }}{% endif %}">

  <link rel="canonical" href="{% if seo and seo.canonical %}{{ seo.canonical }}{% else %}{{ site.site.url }}{{ page.url }}{% endif %}">

  <meta property="og:type" content="article">
  <meta property="og:url" content="https://5kmvp.com{{ page.url }}">
  <meta property="og:title" content="{% if seo and seo.title %}{{ seo.title }}{% else %}{{ title }}{% endif %}">
  <meta property="og:description" content="{% if seo and seo.description %}{{ seo.description }}{% else %}{{ description | default(site.site.description) }}{% endif %}">
  {% if seo and seo.ogImage %}
  <meta property="og:image" content="{{ seo.ogImage }}">
  {% elseif image %}
  <meta property="og:image" content="{{ image }}">
  {% endif %}
  <meta property="og:site_name" content="{{ site.site.name }}">
  <meta property="og:locale" content="{{ site.site.locale | default('en_US') }}">

  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="{% if seo and seo.title %}{{ seo.title }}{% else %}{{ title }}{% endif %}">
  <meta name="twitter:description" content="{% if seo and seo.description %}{{ seo.description }}{% else %}{{ description | default(site.site.description) }}{% endif %}">
  {% if seo and seo.ogImage %}
  <meta name="twitter:image" content="{{ seo.ogImage }}">
  {% elseif image %}
  <meta name="twitter:image" content="{{ image }}">
  {% endif %}

  {% if seo and seo.noindex %}
  <meta name="robots" content="noindex,nofollow">
  {% else %}
  <meta name="robots" content="index,follow">
  {% endif %}

  <link rel="icon" type="image/svg+xml" href="/favicon.svg">
  <link rel="alternate" type="application/rss+xml" title="{{ site.site.name }} RSS" href="/feed.xml">
  <link rel="stylesheet" href="/assets/css/styles.css">

  {% include "partials/schema.njk" %}
  {% include "partials/organization-schema.njk" %}
</head>
<body class="min-h-screen bg-background text-foreground antialiased">
  {% include "header.njk" %}

  <main id="main-content">
    {{ content | safe }}
  </main>

  {% include "footer.njk" %}

  <script defer src="https://unpkg.com/lucide@latest"></script>
  <script defer>
    window.addEventListener('DOMContentLoaded', function() {
      if (window.lucide) {
        window.lucide.createIcons();
      }
    });
  </script>
</body>
</html>
