---
layout: base.njk
---
<article class="min-h-screen">
  <header class="bg-muted/30">
    <div class="container mx-auto px-4 py-12">
      <nav class="mb-6 flex items-center gap-2 text-sm text-muted-foreground" aria-label="Breadcrumb">
        <a href="/" class="hover:text-foreground">Home</a>
        <span>/</span>
        <a href="/{{ type | lower }}s/" class="hover:text-foreground">{{ type | capitalize }}</a>
        <span>/</span>
        <span class="text-foreground">{{ title }}</span>
      </nav>

      <div class="mx-auto max-w-4xl">
        <div class="mb-4 flex flex-wrap items-center gap-2">
          <a href="/{{ type | lower }}s/" class="inline-block rounded-full bg-primary px-4 py-1.5 text-sm font-semibold text-primary-foreground">
            {{ type | capitalize }}
          </a>
        </div>

        <h1 class="mb-4 text-3xl font-bold md:text-4xl lg:text-5xl">
          {{ title }}
        </h1>

        <p class="mb-4 text-lg text-muted-foreground md:text-xl">
          {{ description }}
        </p>

        <div class="mb-6 text-sm text-muted-foreground">
          By {{ author }} • {{ date | dateFormat }} • {{ content | readingTime }} min read • {{ type }}
        </div>
      </div>
      </div>
    </div>
  </header>

  {% if image %}
  <div class="container mx-auto px-4 -mt-4 relative z-10">
    <div class="mx-auto max-w-5xl">
      <img src="{{ image }}" alt="{{ title }}" loading="eager" class="w-full rounded-2xl object-cover shadow-xl">
    </div>
  </div>
  {% endif %}

  <div class="container mx-auto px-4 py-12">
    <div class="mx-auto max-w-3xl">
      <div class="prose prose-neutral dark:prose-invert max-w-none prose-headings:font-bold prose-a:text-primary">
        {{ content | safe }}
      </div>

      {% if tags and tags.length > 0 %}
      <div class="my-8 border-t pt-8">
        <h3 class="mb-3 text-sm font-medium">Tags:</h3>
        <div class="flex flex-wrap gap-2">
          {% for tag in tags %}
          <a href="/tags/{{ tag }}" class="rounded-full bg-muted px-3 py-1.5 text-sm text-muted-foreground hover:bg-primary hover:text-primary-foreground">{{ tag }}</a>
          {% endfor %}
        </div>
      </div>
      {% endif %}
    </div>

  </div>
</article>
