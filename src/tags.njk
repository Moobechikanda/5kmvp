---
layout: base.njk
permalink: /tags/{{ tag }}/index.html
pagination:
  data: collections.allTags
  size: 1
  alias: tag
---

{% set taggedArticles = collections.articles | filterByTag(tag) %}

<section class="bg-muted/30">
  <div class="container mx-auto px-4 py-12">
    <nav class="mb-6 flex items-center gap-2 text-sm text-muted-foreground">
      <a href="/" class="hover:text-foreground">Home</a>
      <span>/</span>
      <a href="/tags" class="hover:text-foreground">Tags</a>
      <span>/</span>
      <span class="text-foreground">{{ tag }}</span>
    </nav>

    <h1 class="mb-4 text-4xl font-bold">
      Tagged: <span class="text-primary">{{ tag }}</span>
    </h1>
    <p class="text-muted-foreground">{{ taggedArticles.length }} articles</p>
  </div>
</section>

<section class="container mx-auto px-4 py-12">
  <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
    {% for article in taggedArticles %}
    <article class="group relative overflow-hidden rounded-xl border bg-card transition-all hover:shadow-lg">
      <a href="{{ article.url }}">
        {% if article.data.image %}
        <div class="aspect-video overflow-hidden">
          <img
            src="{{ article.data.image.url }}"
            alt="{{ article.data.image.alt }}"
            loading="lazy"
            class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
          />
        </div>
        {% endif %}
        <div class="p-5">
          <div class="mb-3 flex items-center gap-2">
            <span class="inline-block rounded-full bg-primary/10 px-3 py-1 text-xs font-medium text-primary">
              {{ article.data.category | capitalize }}
            </span>
          </div>
          <h3 class="mb-2 text-xl font-bold leading-tight group-hover:text-primary">
            {{ article.data.title }}
          </h3>
          <p class="mb-4 line-clamp-2 text-muted-foreground">
            {{ article.data.description }}
          </p>
          <div class="flex items-center justify-between text-sm text-muted-foreground">
            <time datetime="{{ article.data.pubDate | dateFormat('iso') }}">
              {{ article.data.pubDate | dateFormat }}
            </time>
            {% if article.data.readingTime %}
            <span>{{ article.data.readingTime }} min read</span>
            {% endif %}
          </div>
        </div>
      </a>
    </article>
    {% endfor %}
  </div>
</section>
